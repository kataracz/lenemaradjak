{
  "name": "lenemaradjak",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:server": "node server/proxy-server.js",
    "docker:build": "docker build -t lenemaradjak-proxy .",
    "docker:proxy": "docker run --rm -p 3001:3001 -e PORT=3001 --env-file .env lenemaradjak-proxy",
    "dev:all": "npm run docker:proxy & npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@tailwindcss/vite": "^4.3.1",
    "@upstash/redis": "^1.38.0",
    "@videojs/react": "^10.0.0-beta.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint-plugin-react-dom": "^5.10.0",
    "eslint-plugin-react-x": "^5.10.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.7.0",
    "react-grid-layout": "^2.2.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-resizable": "^4.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "shadcn": "^4.12.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
